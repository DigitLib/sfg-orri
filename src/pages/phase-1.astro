---
import Layout from '../layouts/Layout.astro';
import PhaseChecklist from '../components/PhaseChecklist.jsx';
import checklistData from '../data/checklist-data.json';

// Notice we select phase1 here
const phaseData = checklistData.phase1;
---

<Layout title={phaseData.title}>
  <PhaseChecklist 
    client:load 
    phaseKey="phase1" 
    phaseData={phaseData} 
  />
</Layout>