---
import '../styles/global.css';
const { title } = Astro.props;

// Strip any trailing slash to make link building cleaner
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | ORRI Governance Hub</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    
    <header class="bg-blue-900 text-white p-4 shadow-md shrink-0">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center">
        <h1 class="text-xl font-bold mb-2 sm:mb-0">Safeguard-DH ORRI Hub</h1>
        
        <div class="flex items-center space-x-6">
          <nav class="flex flex-wrap gap-x-4 gap-y-2 text-sm items-center z-50">
            <!-- Added ${base} to all hrefs -->
            <a href={`${base}/`} class="hover:underline text-blue-200" id="nav-dash">Dashboard</a>
            <a href={`${base}/about`} class="hover:underline text-blue-200" id="nav-about">About</a>
            <a href={`${base}/instructions`} class="hover:underline text-blue-200" id="nav-inst">Instructions</a>
            
            <div class="relative group">
              <button class="hover:underline flex items-center focus:outline-none py-2" id="nav-phases">
                Phases ▾
              </button>
              <div class="absolute left-0 top-full pt-1 w-32 hidden group-hover:block z-50">
                <div class="bg-white rounded-md shadow-lg border border-gray-200 py-1">
                  <!-- Added ${base} to all phase links -->
                  <a href={`${base}/phase-0`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="0">Phase 0</a>
                  <a href={`${base}/phase-1`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="1">Phase 1</a>
                  <a href={`${base}/phase-2`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="2">Phase 2</a>
                  <a href={`${base}/phase-3`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="3">Phase 3</a>
                  <a href={`${base}/phase-4`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="4">Phase 4</a>
                  <a href={`${base}/phase-5`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="5">Phase 5</a>
                  <a href={`${base}/phase-6`} class="block px-4 py-2 text-gray-800 hover:bg-gray-100 transition-colors phase-link" data-num="6">Phase 6</a>
                </div>
              </div>
            </div>

            <a href={`${base}/dossier`} class="hover:underline font-bold text-yellow-300" id="nav-dossier">Dossier</a>
          </nav>
          
          <select id="lang-switch" class="bg-blue-800 text-white text-sm border border-blue-700 rounded px-2 py-1 focus:ring-blue-500 outline-none cursor-pointer">
            <option value="en">EN</option>
            <option value="sr">SR</option>
          </select>
        </div>
      </div>
    </header>

    <main class="max-w-4xl w-full mx-auto p-6 mt-6 flex-grow">
      <slot />
    </main>

    <footer class="bg-white border-t border-gray-200 mt-12 py-8 shrink-0">
      <div class="max-w-4xl mx-auto px-6 flex flex-col items-center justify-center text-center">
        <a href="https://safeguard.kreativalab.org/" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105 duration-300 ease-in-out">
          <!-- Added ${base} to the image src so it loads properly -->
          <img src={`${base}/Safeguard-logo.png`} alt="Safeguard-DH Logo" class="h-32 w-auto object-contain mb-4" />
        </a>
        <p class="text-xs text-gray-400 font-medium tracking-wide uppercase">Responsible &bull; Participatory &bull; Ethical</p>
        <p class="text-xs text-gray-400 mt-1">AI in Digitalization of Cultural Heritage</p>
      </div>
    </footer>

    <script>
      const switcher = document.getElementById('lang-switch') as HTMLSelectElement | null;
      const navDash = document.getElementById('nav-dash') as HTMLAnchorElement | null;
      const navAbout = document.getElementById('nav-about') as HTMLAnchorElement | null;
      const navInst = document.getElementById('nav-inst') as HTMLAnchorElement | null;
      const navPhases = document.getElementById('nav-phases') as HTMLButtonElement | null;
      const navDossier = document.getElementById('nav-dossier') as HTMLAnchorElement | null;
      const phaseLinks = document.querySelectorAll('.phase-link');
      
      const currentLang = localStorage.getItem('app_lang') || 'en';

      if (currentLang === 'sr') {
        if (navDash) navDash.innerText = 'Kontrolna tabla';
        if (navAbout) navAbout.innerText = 'O alatu';
        if (navInst) navInst.innerText = 'Uputstva';
        if (navPhases) navPhases.innerText = 'Faze ▾';
        if (navDossier) navDossier.innerText = 'Dosije';
        
        phaseLinks.forEach((link) => {
          const num = link.getAttribute('data-num');
          (link as HTMLAnchorElement).innerText = `Faza ${num}`;
        });
        
        document.documentElement.lang = 'sr';
      }

      if (switcher) {
        switcher.value = currentLang;
        switcher.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          localStorage.setItem('app_lang', target.value);
          window.location.reload(); 
        });
      }
    </script>
  </body>
</html>